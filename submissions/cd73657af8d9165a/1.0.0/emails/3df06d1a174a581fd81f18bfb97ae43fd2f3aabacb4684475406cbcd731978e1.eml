    }

    .meter-label {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 12px;
      display: flex;
      justify-content: space-between;
    }

    .meter-track {
      height: 28px;
      background-color: #e8eaed;
      border-radius: 14px;
      display: flex;
      overflow: hidden;
    }

    /* Segments using the 4-color palette */
    .segment-blue { width: 40%; background-color: var(--brand-blue); }
    .segment-green { width: 30%; background-color: var(--brand-green); }
    .segment-yellow { width: 20%; background-color: var(--brand-yellow); }
    .segment-red { width: 10%; background-color: var(--brand-red); }

    /* Service Key Grid */
    .service-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 24px 0;
      padding: 20px;
      background: var(--bg-light);
      border-radius: 12px;
      text-align: left;
    }

    .service-item {
      font-size: 15px;
      font-weight: 500;
      display: flex;
      align-items: center;
    }

    .swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      margin-right: 10px;
      flex-shrink: 0;
    }

    /* CTA Section */
    .cta-area {
      margin-top: 40px;
    }

    .primary-button {
      display: block;
      background-color: var(--brand-blue);
      color: #ffffff;
      text-decoration: none;
      padding: 22px;
      font-size: 22px;
      font-weight: 700;
      border-radius: 8px;
      margin-bottom: 16px;
      box-shadow: 0 4px 0 #185abc;
    }

    .secondary-link {
      color: var(--brand-blue);
      text-decoration: underline;
      font-weight: 500;
      font-size: 16px;
    }

    /* Footer */
    .email-footer {
      padding: 40px;
      text-align: center;
      font-size: 13px;
      color: var(--brand-gray);
      background-color: var(--bg-light);
      border-top: 1px solid var(--border-color);
    }

    .promo-tag {
      display: inline-block;
      background: #e6f4ea;
      color: #137333;
      padding: 6px 16px;
      border-radius: 20px;
      font-weight: 700;
      margin-bottom: 20px;
      border: 1px solid var(--brand-green);
    }

    @media (max-width: 480px) {
      .brand-header img { height: 80px; }
      .headline { font-size: 24px; }
      .service-grid { grid-template-columns: 1fr; }
    }
