  <style>
    /* Google Brand Palette */
    :root {
      --brand-blue: #4285F4;
      --brand-red: #EA4335;
      --brand-yellow: #FBBC05;
      --brand-green: #34A853;
      --brand-gray: #5f6368;
      --bg-light: #f8f9fa;
      --border-color: #dadce0;
    }

    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'Google Sans', Roboto, Arial, sans-serif;
      background-color: #f1f3f4;
      color: #3c4043;
      padding: 40px 15px;
      line-height: 1.6;
    }

    /* Email Container */
    .email-wrapper {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      border: 1px solid var(--border-color);
    }

    /* GIANT LOGO HEADER */
    .brand-header {
      padding: 50px 32px 30px;
      text-align: center;
      background: #ffffff;
      border-bottom: 4px solid var(--brand-blue); /* Distinctive color bord=
er */
    }

    .brand-header img {
      height: 120px; /* Max visibility for elderly users */
      width: auto;
      display: block;
      margin: 0 auto;
    }

    .content-body {
      padding: 40px;
      text-align: center;
    }

    .headline {
      font-size: 32px;
      font-weight: 500;
      color: #202124;
      margin-bottom: 12px;
    }

    /* Red Warning Box */
    .status-alert-box {
      background-color: #fce8e6;
      border: 2px solid var(--brand-red);
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 32px;
    }

    .status-alert-box strong {
      display: block;
      font-size: 20px;
      color: var(--brand-red);
      margin-bottom: 4px;
    }

    /* Quad-Color Multi-Segment Progress Meter */
    .storage-meter {
      margin: 32px 0;
      text-align: left;
    }

    .meter-label {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 12px;
      display: flex;
      justify-content: space-between;
    }

    .meter-track {
      height: 28px;
      background-color: #e8eaed;
      border-radius: 14px;
      display: flex;
      overflow: hidden;
    }

    /* Segments using the 4-color palette */
    .segment-blue { width: 40%; background-color: var(--brand-blue); }
    .segment-green { width: 30%; background-color: var(--brand-green); }
    .segment-yellow { width: 20%; background-color: var(--brand-yellow); }
    .segment-red { width: 10%; background-color: var(--brand-red); }

    /* Service Key Grid */
    .service-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 24px 0;
      padding: 20px;
      background: var(--bg-light);
      border-radius: 12px;
      text-align: left;
    }

    .service-item {
      font-size: 15px;
      font-weight: 500;
      display: flex;
      align-items: center;
    }

    .swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      margin-right: 10px;
      flex-shrink: 0;
    }

    /* CTA Section */
    .cta-area {
      margin-top: 40px;
    }

    .primary-button {
      display: block;
      background-color: var(--brand-blue);
      color: #ffffff;
      text-decoration: none;
      padding: 22px;
      font-size: 22px;
      font-weight: 700;
      border-radius: 8px;
      margin-bottom: 16px;
      box-shadow: 0 4px 0 #185abc;
    }

    .secondary-link {
      color: var(--brand-blue);
      text-decoration: underline;
      font-weight: 500;
      font-size: 16px;
    }

    /* Footer */
    .email-footer {
      padding: 40px;
      text-align: center;
      font-size: 13px;
      color: var(--brand-gray);
      background-color: var(--bg-light);
      border-top: 1px solid var(--border-color);
    }

    .promo-tag {
      display: inline-block;
      background: #e6f4ea;
      color: #137333;
      padding: 6px 16px;
      border-radius: 20px;
      font-weight: 700;
      margin-bottom: 20px;
      border: 1px solid var(--brand-green);
    }

    @media (max-width: 480px) {
      .brand-header img { height: 80px; }
      .headline { font-size: 24px; }
      .service-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
