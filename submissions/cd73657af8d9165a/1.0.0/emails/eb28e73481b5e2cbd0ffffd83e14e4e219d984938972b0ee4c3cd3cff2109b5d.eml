      background-color: #f1f3f4;
      color: #3c4043;
      padding: 40px 15px;
      line-height: 1.6;
    }

    /* Email Container */
    .email-wrapper {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      border: 1px solid var(--border-color);
    }

    /* GIANT LOGO HEADER */
    .brand-header {
